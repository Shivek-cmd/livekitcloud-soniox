# LiveKit Cloud project (wss URL + API key/secret from the Cloud dashboard)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Soniox (STT + TTS) — https://console.soniox.com/
SONIOX_API_KEY=your_soniox_api_key
# STT endpoint detection (PR 064/066) — how fast Soniox finalizes after speech stops.
# Delay in ms (500-3000, default 1000); sensitivity -1.0..1.0 (default 0.3 =
# Soniox voice-AI rec, higher = finalize sooner but may cut off mid-sentence
# pauses); latency adjustment level 0-3 (default 2, higher = lower latency).
# Set sensitivity/level to "none" to fall back to the Soniox server defaults.
SONIOX_MAX_ENDPOINT_DELAY_MS=1000
#SONIOX_ENDPOINT_SENSITIVITY=0.3
#SONIOX_ENDPOINT_LATENCY_ADJUSTMENT_LEVEL=2

# Silero VAD tuning (PR 066) — explicit VAD so end-of-speech timing is trusted
# in noisy calls. Threshold: lib default 0.5, ours 0.6, LiveKit noisy example ~0.7.
#VAD_ACTIVATION_THRESHOLD=0.6
#VAD_MIN_SILENCE_SEC=0.25

# EOU watchdog (PR 067) — if no final transcript arrives this many seconds
# after the VAD says the caller stopped speaking, force-commit the turn from
# the interim transcript (bounds noisy-call dead air). 0 disables.
#EOU_WATCHDOG_SEC=2.0

# OpenAI (GPT LLM)
OPENAI_API_KEY=your_openai_api_key

# Twilio (for placing outbound test calls via scripts/test_call.py)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Clover sandbox (Phase 8a+) — test Merchant Dashboard only; never commit real values
CLOVER_BASE_URL=https://apisandbox.dev.clover.com
CLOVER_MID=your_13_char_merchant_id
CLOVER_API_TOKEN=your_sandbox_api_token
# Sandbox order type IDs (from clover_sandbox_probe.py)
CLOVER_ORDER_TYPE_PICKUP_ID=
CLOVER_ORDER_TYPE_DELIVERY_ID=

# Phase 8b — Clover menu cache (single tenant demo)
USE_CLOVER_MENU=0
TENANT_DB_PATH=data/tenants.db
VOICE_LABELS_PATH=data/clover_voice_labels.json
MENU_CACHE_PATH=data/menu_cache_bizbull.json

# Phase 8c — submit confirmed orders to Clover (sandbox/production)
# Requires USE_CLOVER_MENU=1 + synced menu cache with clover_item_id on each line.
CLOVER_SUBMIT_ORDERS=0
CLOVER_PRINT_ORDERS=1

# Store optional pay-now (PR 090) — Clover Hosted Checkout
# Requires Ecommerce "Hosted Checkout" private API token from Merchant Dashboard.
# Kill switch default off until token is set on VPS.
STORE_PAY_NOW_ENABLED=0
CLOVER_ECOM_PRIVATE_TOKEN=
# Optional aliases / page config
# CLOVER_HOSTED_CHECKOUT_TOKEN=   # same as CLOVER_ECOM_PRIVATE_TOKEN if set
# CLOVER_HCO_PAGE_CONFIG_UUID=
# After pay, Clover can redirect here (HTTPS). Local example: http://localhost:5173/
STORE_PAY_SUCCESS_URL=
STORE_PAY_FAILURE_URL=

# Web Store checkout rate limit (PR 089 S5) — per client IP on token_server
STORE_CHECKOUT_RATE_LIMIT=20
STORE_CHECKOUT_RATE_WINDOW_SEC=60
# Demo Unsplash fill for missing Clover item photos (Store GET /menu). Set 0 to disable.
STORE_DEMO_IMAGES=1

# Sierra analytics — Supabase project sierra-bizbull (ca-central-1)
# Dashboard: https://admin.bizbull.ai
SUPABASE_URL=https://lzlwivsntqkpxfwjktid.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SESSION_ANALYTICS_ENABLED=1
SESSION_FALLBACK_DIR=data/sessions

# Auto hang-up after successful place_order (phone + web)
AUTO_HANGUP_AFTER_ORDER=1
AUTO_HANGUP_GRACE_SEC=1.0

# GHL via n8n — order.placed webhook (PR 071). Default off until VPS ready.
# Prod URL: https://n8n.bizbull.ai/webhook/sierra-ghl-sync
N8N_SYNC_ENABLED=0
N8N_WEBHOOK_ORDERS_URL=
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_TIMEOUT_SEC=3.0

# Voice fillers before LLM on selected intents (phone + web). Off until validated on VPS.
FILLERS_ENABLED=0

# Minimum gap (seconds) between two queued speech handles (PR 042) — prevents
# fillers/ladder lines/LLM replies from blending into one garbled utterance.
MIN_CONSECUTIVE_SPEECH_DELAY_SEC=0.3

# Menu matching (PR 032) — cross-script confidence matcher. Defaults are correct;
# MENU_MATCH_LEGACY=1 restores the pre-032 substring matcher (rollback only).
MENU_MATCH_LEGACY=0
MENU_MATCH_MIN_CONF=0.55
AUTO_ADD_MIN_CONFIDENCE=0.8
AUTO_ADD_MULTI_MIN_CONFIDENCE=0.72
