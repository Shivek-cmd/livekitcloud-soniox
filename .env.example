# LiveKit Cloud project (wss URL + API key/secret from the Cloud dashboard)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Soniox (STT + TTS) — https://console.soniox.com/
SONIOX_API_KEY=your_soniox_api_key

# OpenAI (GPT LLM)
OPENAI_API_KEY=your_openai_api_key

# Twilio (for placing outbound test calls via scripts/test_call.py)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Clover sandbox (Phase 8a+) — test Merchant Dashboard only; never commit real values
CLOVER_BASE_URL=https://apisandbox.dev.clover.com
CLOVER_MID=your_13_char_merchant_id
CLOVER_API_TOKEN=your_sandbox_api_token
# Sandbox order type IDs (from clover_sandbox_probe.py)
CLOVER_ORDER_TYPE_PICKUP_ID=
CLOVER_ORDER_TYPE_DELIVERY_ID=

# Phase 8b — Clover menu cache (single tenant demo)
USE_CLOVER_MENU=0
TENANT_DB_PATH=data/tenants.db
VOICE_LABELS_PATH=data/clover_voice_labels.json

# Sierra analytics — Supabase project sierra-bizbull (ca-central-1)
# Dashboard: https://admin.bizbull.ai
SUPABASE_URL=https://lzlwivsntqkpxfwjktid.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SESSION_ANALYTICS_ENABLED=1
SESSION_FALLBACK_DIR=data/sessions

# Auto hang-up after successful place_order (phone + web)
AUTO_HANGUP_AFTER_ORDER=1
AUTO_HANGUP_GRACE_SEC=1.0

# Voice fillers before LLM on selected intents (phone + web). Off until validated on VPS.
FILLERS_ENABLED=0

# Menu matching (PR 032) — cross-script confidence matcher. Defaults are correct;
# MENU_MATCH_LEGACY=1 restores the pre-032 substring matcher (rollback only).
MENU_MATCH_LEGACY=0
MENU_MATCH_MIN_CONF=0.55
AUTO_ADD_MIN_CONFIDENCE=0.8
